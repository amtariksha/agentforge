# Database
DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for tenant credentials)
ENCRYPTION_KEY=change-me-32-byte-hex-key-here!!

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback)
OPENAI_API_KEY=sk-...

# Swarg Food WhatsApp
SWARG_WA_PHONE_ID=
SWARG_WA_WABA_ID=
SWARG_WA_ACCESS_TOKEN=
SWARG_WA_VERIFY_TOKEN=
SWARG_WA_APP_SECRET=

# Swarg LMS integration — shared service tokens (generate via `openssl rand -hex 32`)
# Inbound: admin panel (swarg-admin-nextjs) presents this when calling /api/v1/chat/*/stream
AGENT_FORCE_SERVICE_TOKEN=
# Outbound: chatagent presents this when calling swarg-admin-nextjs /api/agent-tools/*
# Naming: this is the SAME token issued by admin panel (named AGENT_FORCE_SERVICE_TOKEN there);
# here we hold an admin-issued token so we name it from chatagent's perspective.
SWARG_ADMIN_SERVICE_TOKEN=
SWARG_ADMIN_BASE_URL=https://swarg-admin.vercel.app
# HMAC secret for signing outbound agent_run.completed webhooks to admin panel
AGENT_FORCE_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
